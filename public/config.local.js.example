// 本機實際設定範本
//
// 使用方式:
//   cp src/config.local.js.example src/config.local.js
// 然後填入你自己的 Supabase 專案值。
//
// 警告:
//   1. config.local.js 已在 .gitignore,不會被 commit(請勿自行移除)
//   2. SUPABASE_ANON_KEY 只能填 "anon public" key,絕對不可填 "service_role" key
//      service_role 擁有繞過 RLS 的能力,若外流整個資料庫等同裸奔
window.CONFIG = {
  // Supabase Dashboard → Project Settings → API → Project URL
  SUPABASE_URL: 'https://你的專案.supabase.co',

  // Supabase Dashboard → Project Settings → API → Project API keys → anon public
  SUPABASE_ANON_KEY: '在此填入你的 anon key',

  // 學校 email 網域
  EMAIL_DOMAIN: 'mail.fju.edu.tw',

  // 本機開發用 http://localhost:5173,部署時改成實際網址
  SITE_URL: 'http://localhost:5173'
};
