# ChemWordle 環境變數範本
#
# 用途分兩種:
#
# 1. 本機開發(npm run dev):
#    不需要使用這個 .env 檔。請複製 public/config.local.js.example 成
#    public/config.local.js 並直接編輯填值。dev server 會在執行時讀取它。
#
# 2. CI / Cloudflare Pages production build(npm run build):
#    在 Cloudflare Pages dashboard → Settings → Environment variables 設定
#    以下 4 個變數。build 流程的 prebuild 步驟會讀取它們並產生
#    public/config.js,讓 vite build 把實值打包進 dist/config.js。

# ── 必要 ─────────────────────────────────────

# Supabase 專案 URL(Dashboard → Project Settings → API → Project URL)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Supabase anon key(Dashboard → Project Settings → API → Project API keys → anon public)
#
# ⚠️ 警告:絕對不可填 service_role key。
# generate-config.js 會檢查 JWT payload,若是 service_role 會直接 abort build。
SUPABASE_ANON_KEY=YOUR_ANON_KEY

# 學校 email 網域(學生 email = 學號 + @ + EMAIL_DOMAIN)
EMAIL_DOMAIN=mail.fju.edu.tw

# 網站自身 URL,給 Magic Link 的 redirectTo 用
# 本機:        http://localhost:5173
# CF Pages:   https://你的網域.pages.dev   (或自訂網域)
SITE_URL=http://localhost:5173
